generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  password      String    @default("")
  avatar        String?
  locale        String    @default("ko")
  provider      String    @default("credentials") // "credentials" | "google" | "github"

  pages         Page[]    @relation("PageOwner")
  comments      Comment[]
  memberships   WorkspaceMember[]
  notifications Notification[]
  
  createdAt     DateTime  @default(now())
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  icon        String?
  
  members     WorkspaceMember[]
  pages       Page[]
  invites     WorkspaceInvite[]
  
  createdAt   DateTime @default(now())
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  role        String   @default("editor") // "owner" | "admin" | "editor" | "viewer"
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  joinedAt    DateTime @default(now())
  
  @@unique([userId, workspaceId])
}

model WorkspaceInvite {
  id          String   @id @default(uuid())
  code        String   @unique @default(uuid())
  role        String   @default("editor")
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  expiresAt   DateTime?
  usedAt      DateTime?
  usedById    String?
  
  createdAt   DateTime @default(now())
}

model Page {
  id         String   @id @default(uuid())
  title      String   @default("제목 없음")
  content    String   @default("")
  icon       String?
  coverImage String?

  parentId   String?
  parent     Page?    @relation("PageHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children   Page[]   @relation("PageHierarchy")

  ownerId    String?
  owner      User?    @relation("PageOwner", fields: [ownerId], references: [id])

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  isBoard    Boolean  @default(false)
  status     String   @default("To Do")
  priority   String   @default("없음")
  dueDate    DateTime?

  isFavorite Boolean  @default(false)
  isDeleted  Boolean  @default(false)
  deletedAt  DateTime?
  isLocked   Boolean  @default(false)

  isPublic   Boolean  @default(false)
  shareLink  String?  @unique
  
  properties String?  @default("{}") // Stores custom JSON properties
  
  isFullWidth Boolean @default(false)
  sortOrder   Int     @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  comments   Comment[]
  history    PageHistory[]
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  author    String   @default("익명")

  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model PageHistory {
  id        String   @id @default(uuid())
  content   String
  title     String

  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Template {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  content     String   @default("")
  icon        String?

  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // "mention" | "comment" | "invite"
  message   String
  link      String?  // URL to navigate to
  isRead    Boolean  @default(false)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fromUser  String?  // Who triggered this notification

  createdAt DateTime @default(now())
}
